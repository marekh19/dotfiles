# Colorscheme
theme = dark:/Users/marekhonzal/zenbones.nvim/extras/ghostty/tokyobones_dark,light:/Users/marekhonzal/zenbones.nvim/extras/ghostty/tokyobones_light

# Fonts
font-size = 15

# Main font family
font-family = Monaspace Neon

font-style = Medium
font-style-bold = ExtraBold
font-style-italic = Medium Italic
font-style-bold-italic = ExtraBold Italic

# Ligatures
font-feature = calt
font-feature = liga
font-feature = ss01
font-feature = ss02
font-feature = ss03
font-feature = ss04
font-feature = ss05
font-feature = ss06
font-feature = ss07
font-feature = ss08
font-feature = ss09

# Fallback font for icons
font-family = Symbols Nerd Font Mono

# Window
macos-titlebar-style = hidden

window-padding-x = 4
window-padding-y = 2

shell-integration = fish

custom-shader = shaders/cursor_warp.glsl
